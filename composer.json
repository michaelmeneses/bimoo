{
    "name": "michaelmeneses/bimoo",
    "description": "Moodle PHP stub generator — generates .stub.php files for IDE and static analysis support",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Mohammad Amin Chitgarha",
            "email": "machitgarha@outlook.com",
            "homepage": "https://github.com/machitgarha",
            "role": "Original Creator"
        },
        {
            "name": "Michael Meneses",
            "homepage": "https://github.com/michaelmeneses",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.1",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^6.0|^7.0",
        "symfony/finder": "^6.0|^7.0",
        "symfony/filesystem": "^6.0|^7.0",
        "symfony/process": "^6.0|^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Bimoo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bimoo\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/bimoo"
    ],
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "quality": [
            "@cs:check",
            "@analyse",
            "@test"
        ]
    }
}
